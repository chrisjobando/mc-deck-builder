---
interface Props {
  id: string;
  title: string;
  description?: string;
}

const { id, title, description } = Astro.props;
---

<section id={id} class="scroll-mt-24 space-y-6 border-t border-border/60 py-12 first:border-t-0 first:pt-0">
  <header class="space-y-2">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground">{title}</h2>
    {description && (
      <p class="max-w-2xl text-sm text-muted-foreground">{description}</p>
    )}
  </header>
  <div class="space-y-8">
    <slot />
  </div>
</section>
