---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<div class="space-y-4">
  <div class="space-y-1">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">{title}</h3>
    {description && <p class="text-xs text-muted-foreground/80">{description}</p>}
  </div>
  <div>
    <slot />
  </div>
</div>
