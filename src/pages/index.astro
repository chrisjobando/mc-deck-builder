---
import Layout from '../layouts/Layout.astro';
import { getUser } from '../lib/auth';

const user = await getUser(Astro);
---

<Layout title="Home">
  <div>
    <h1>
      <span>Marvel Champions</span>
      <br />
      AI Deck Builder
    </h1>
    <p>
      Build optimized decks for 1-4 players with AI-powered recommendations.
      Share collections with friends and let Claude help you assemble your team.
    </p>
    <div>
      {user ? (
        <>
          <a href="/builder">Start Building</a>
          <a href="/sessions/new">New Session</a>
        </>
      ) : (
        <a href="/api/auth/signin">Sign In to Get Started</a>
      )}
    </div>
  </div>

  <section>
    <div>
      <h3>AI-Powered</h3>
      <p>Claude AI knows the rules, cards, and meta. Get smart deck suggestions based on your hero, aspect, and playstyle.</p>
    </div>
    <div>
      <h3>Multiplayer Sessions</h3>
      <p>Create sessions for 1-4 players. Share collections, pick unique heroes, and build synergistic decks together.</p>
    </div>
    <div>
      <h3>Collection Aware</h3>
      <p>Track your owned packs. The AI only suggests cards you actually have access to.</p>
    </div>
  </section>
</Layout>
