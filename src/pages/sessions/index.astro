---
import Layout from '../../layouts/Layout.astro';
import { getUser } from '../../lib/auth';
import { prisma } from '../../lib/db';

const user = await getUser(Astro);
if (!user) return Astro.redirect('/api/auth/signin');

const sessions = await prisma.session.findMany({
  where: {
    OR: [
      { hostId: user.id as string },
      { participants: { some: { userId: user.id as string } } },
    ],
  },
  include: {
    participants: { select: { userId: true } },
    host: { select: { name: true } },
  },
  orderBy: { updatedAt: 'desc' },
});

const STATUS_LABEL: Record<string, string> = {
  draft: 'Lobby',
  drafting: 'Drafting',
  building: 'Building',
  completed: 'Completed',
};

const STATUS_COLOR: Record<string, string> = {
  draft: 'bg-white/10 text-gray-400',
  drafting: 'bg-yellow-500/20 text-yellow-300',
  building: 'bg-blue-500/20 text-blue-300',
  completed: 'bg-white/10 text-gray-400',
};
---

<Layout title="Sessions">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold">Sessions</h1>
      <p class="mt-1 text-[var(--color-text-muted)]">Coordinate hero picks with your play group</p>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Create session -->
    <div class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold">New Session</h2>
      <form id="create-form" class="space-y-4">
        <div>
          <label class="mb-1 block text-sm text-[var(--color-text-muted)]" for="session-name">Session name</label>
          <input
            id="session-name"
            name="name"
            type="text"
            maxlength="60"
            placeholder="Friday night game"
            required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]"
          />
        </div>
        <div>
          <label class="mb-2 block text-sm text-[var(--color-text-muted)]">Collection</label>
          <div class="space-y-2">
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-white/10 p-3 hover:bg-white/5 has-[:checked]:border-[var(--color-primary)] has-[:checked]:bg-[var(--color-primary)]/10">
              <input type="radio" name="collectionMode" value="combined" checked class="mt-0.5 accent-[var(--color-primary)]" />
              <div>
                <div class="text-sm font-medium">Combined</div>
                <div class="text-xs text-[var(--color-text-muted)]">Union of all players' collections</div>
              </div>
            </label>
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-white/10 p-3 hover:bg-white/5 has-[:checked]:border-[var(--color-primary)] has-[:checked]:bg-[var(--color-primary)]/10">
              <input type="radio" name="collectionMode" value="duplicates" class="mt-0.5 accent-[var(--color-primary)]" />
              <div>
                <div class="text-sm font-medium">Count Duplicates</div>
                <div class="text-xs text-[var(--color-text-muted)]">Sum of all players' collections</div>
              </div>
            </label>
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-white/10 p-3 hover:bg-white/5 has-[:checked]:border-[var(--color-primary)] has-[:checked]:bg-[var(--color-primary)]/10">
              <input type="radio" name="collectionMode" value="single" class="mt-0.5 accent-[var(--color-primary)]" />
              <div>
                <div class="text-sm font-medium">Single Player's Collection</div>
                <div class="text-xs text-[var(--color-text-muted)]">Use only your collection</div>
              </div>
            </label>
          </div>
        </div>
        <div id="create-error" class="hidden rounded-lg bg-red-500/20 px-4 py-2 text-sm text-red-300"></div>
        <button
          type="submit"
          class="w-full rounded-lg bg-[var(--color-primary)] px-4 py-2.5 text-sm font-semibold hover:opacity-90 disabled:opacity-50"
        >
          Create Session
        </button>
      </form>
    </div>

    <!-- Join session -->
    <div class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold">Join a Session</h2>
      <form id="join-form" class="space-y-4">
        <div>
          <label class="mb-1 block text-sm text-[var(--color-text-muted)]" for="invite-code">Invite code</label>
          <input
            id="invite-code"
            name="code"
            type="text"
            maxlength="6"
            placeholder="ABC123"
            required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 font-mono text-sm uppercase outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]"
          />
        </div>
        <div id="join-error" class="hidden rounded-lg bg-red-500/20 px-4 py-2 text-sm text-red-300"></div>
        <button
          type="submit"
          class="w-full rounded-lg border border-[var(--color-primary)] bg-[var(--color-primary)]/20 px-4 py-2.5 text-sm font-semibold text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white disabled:opacity-50"
        >
          Join Session
        </button>
      </form>
    </div>
  </div>

  {sessions.length > 0 && (
    <div class="mt-8">
      <h2 class="mb-4 text-lg font-semibold">Your Sessions</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sessions.map((session) => (
          <div class="group relative rounded-xl border border-white/10 bg-white/5 p-5 transition hover:border-white/20 hover:bg-white/10">
            <a href={`/sessions/${session.inviteCode}`} class="absolute inset-0 z-0"></a>
            <div class="relative z-10 pointer-events-none">
              <div class="mb-3 flex items-start justify-between gap-2">
                <span class="font-semibold group-hover:text-[var(--color-primary)]">{session.name}</span>
                <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${STATUS_COLOR[session.status]}`}>
                  {STATUS_LABEL[session.status]}
                </span>
              </div>
              <div class="flex items-center justify-between text-sm text-[var(--color-text-muted)]">
                <span>{session.participants.length}/4 players</span>
                <span class="font-mono text-xs">{session.inviteCode}</span>
              </div>
              {session.hostId !== (user.id as string) && (
                <div class="mt-1 text-xs text-[var(--color-text-muted)]">Hosted by {session.host.name}</div>
              )}
              {session.hostId === (user.id as string) && (
                <button
                  type="button"
                  data-delete-session={session.inviteCode}
                  class="pointer-events-auto mt-3 rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-500/20"
                >
                  Delete
                </button>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</Layout>

<script>
  import { showAlert, showConfirm } from '../../lib/dialog';

  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const joinForm = document.getElementById('join-form') as HTMLFormElement;
  const createError = document.getElementById('create-error')!;
  const joinError = document.getElementById('join-error')!;

  function showError(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    createError.classList.add('hidden');
    const btn = createForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Creating…';

    const data = new FormData(createForm);
    try {
      const res = await fetch('/api/sessions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          collectionMode: data.get('collectionMode'),
        }),
      });
      const json = await res.json();
      if (!res.ok) { showError(createError, json.error ?? 'Something went wrong'); return; }
      window.location.href = `/sessions/${json.inviteCode}`;
    } catch {
      showError(createError, 'Network error — please try again');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create Session';
    }
  });

  joinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    joinError.classList.add('hidden');
    const btn = joinForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Joining…';

    const data = new FormData(joinForm);
    const code = (data.get('code') as string).toUpperCase().trim();
    try {
      const res = await fetch(`/api/sessions/${code}/join`, { method: 'POST' });
      const json = await res.json();
      if (!res.ok) { showError(joinError, json.error ?? 'Something went wrong'); return; }
      window.location.href = `/sessions/${code}`;
    } catch {
      showError(joinError, 'Network error — please try again');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join Session';
    }
  });

  // Delete session handlers
  document.querySelectorAll<HTMLButtonElement>('[data-delete-session]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const code = btn.dataset.deleteSession;
      if (!code) return;
      const confirmed = await showConfirm('This cannot be undone.', { title: 'Delete session?', confirmLabel: 'Delete', danger: true });
      if (!confirmed) return;
      btn.disabled = true;
      btn.textContent = 'Deleting…';
      try {
        const res = await fetch(`/api/sessions/${code}`, { method: 'DELETE' });
        if (res.ok) {
          btn.closest('.group')?.remove();
        } else {
          await showAlert('Failed to delete session.');
          btn.disabled = false;
          btn.textContent = 'Delete';
        }
      } catch {
        await showAlert('Failed to delete session.');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });
  });
</script>
