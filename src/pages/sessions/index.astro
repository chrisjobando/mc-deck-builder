---
import Layout from '../../layouts/Layout.astro';
import { getUser } from '../../lib/auth';
import { prisma } from '../../lib/db';
import { STATUS_LABEL } from '../../lib/sessions';
import { loadEncounterSets } from '../../lib/builder-data';

const user = await getUser(Astro);
if (!user) return Astro.redirect('/api/auth/signin');

const [encounterSets, sessions] = await Promise.all([
  loadEncounterSets(),
  prisma.session.findMany({
    where: {
      OR: [
        { hostId: user.id as string },
        { participants: { some: { userId: user.id as string } } },
      ],
    },
    include: {
      participants: { select: { userId: true } },
      host: { select: { name: true } },
    },
    orderBy: { updatedAt: 'desc' },
  }),
]);
---

<div id="encounter-sets-data"
  data-villain={JSON.stringify(encounterSets.filter(s => s.setType === 'villain'))}
  data-modular={JSON.stringify(encounterSets.filter(s => s.setType === 'modular'))}
  hidden
></div>

<Layout title="Sessions">
  <div>
    <h1>Sessions</h1>
    <p>Coordinate hero picks with your play group</p>
  </div>

  <div>
    <!-- Create session -->
    <div>
      <h2>New Session</h2>
      <form id="create-form">
        <div>
          <label for="session-name">Session name</label>
          <input
            id="session-name"
            name="name"
            type="text"
            maxlength="60"
            placeholder="Friday night game"
            required
          />
        </div>
        <div>
          <label>Collection</label>
          <div>
            <label>
              <input type="radio" name="collectionMode" value="combined" checked />
              <div>
                <div>Combined</div>
                <div>Union of all players' collections</div>
              </div>
            </label>
            <label>
              <input type="radio" name="collectionMode" value="duplicates" />
              <div>
                <div>Count Duplicates</div>
                <div>Sum of all players' collections</div>
              </div>
            </label>
            <label>
              <input type="radio" name="collectionMode" value="single" />
              <div>
                <div>Single Player's Collection</div>
                <div>Use only your collection</div>
              </div>
            </label>
          </div>
        </div>
        <div>
          <label>Scenario <span>(optional - for AI suggestions)</span></label>
          <input
            id="villain-search"
            type="text"
            placeholder="Search villain or scenario"
            autocomplete="off"
          />
          <input type="hidden" name="villainSetCode" id="villain-code" />
          <div id="villain-dropdown" class="hidden">
            <ul></ul>
          </div>
          <div id="villain-selected" class="hidden">
            <span id="villain-selected-name"></span>
            <button type="button" id="villain-clear">✕</button>
          </div>
          <div>
            <input
              id="modular-search"
              type="text"
              placeholder="Add modular set"
              autocomplete="off"
            />
            <div id="modular-dropdown" class="hidden">
              <ul></ul>
            </div>
            <div id="modular-pills"></div>
            <input type="hidden" name="modularSetCodes" id="modular-codes" value="[]" />
          </div>
        </div>
        <div id="create-error" class="hidden"></div>
        <button type="submit">Create Session</button>
      </form>
    </div>

    <!-- Join session -->
    <div>
      <h2>Join a Session</h2>
      <form id="join-form">
        <div>
          <label for="invite-code">Invite code</label>
          <input
            id="invite-code"
            name="code"
            type="text"
            maxlength="6"
            placeholder="ABC123"
            required
          />
        </div>
        <div id="join-error" class="hidden"></div>
        <button type="submit">Join Session</button>
      </form>
    </div>
  </div>

  {sessions.length > 0 && (
    <div>
      <h2>Your Sessions</h2>
      <div>
        {sessions.map((session) => (
          <div class="group" style="position: relative;">
            <a href={`/sessions/${session.inviteCode}`} style="position: absolute; inset: 0;"></a>
            <div style="position: relative; pointer-events: none;">
              <div>
                <span>{session.name}</span>
                <span>{STATUS_LABEL[session.status]}</span>
              </div>
              <div>
                <span>{session.participants.length}/4 players</span>
                <span>{session.inviteCode}</span>
              </div>
              {session.hostId !== (user.id as string) && (
                <div>Hosted by {session.host.name}</div>
              )}
              {session.hostId === (user.id as string) && (
                <button
                  type="button"
                  data-delete-session={session.inviteCode}
                  style="pointer-events: auto;"
                >
                  Delete
                </button>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</Layout>

<script>
  import { showAlert, showConfirm } from '../../lib/dialog';

  type EncounterSet = { setCode: string; setName: string; setType: string; packName: string | null };
  const setsEl = document.getElementById('encounter-sets-data')!;
  const villainSets: EncounterSet[] = JSON.parse(setsEl.dataset.villain ?? '[]');
  const modularSets: EncounterSet[] = JSON.parse(setsEl.dataset.modular ?? '[]');

  const villainSearch = document.getElementById('villain-search') as HTMLInputElement;
  const villainCode = document.getElementById('villain-code') as HTMLInputElement;
  const villainDropdownWrap = document.getElementById('villain-dropdown')!;
  const villainDropdownList = villainDropdownWrap.querySelector('ul')!;
  const villainSelected = document.getElementById('villain-selected')!;
  const villainSelectedName = document.getElementById('villain-selected-name')!;
  const villainClear = document.getElementById('villain-clear')!;

  const modularSearch = document.getElementById('modular-search') as HTMLInputElement;
  const modularDropdownWrap = document.getElementById('modular-dropdown')!;
  const modularDropdownList = modularDropdownWrap.querySelector('ul')!;
  const modularPills = document.getElementById('modular-pills')!;
  const modularCodesInput = document.getElementById('modular-codes') as HTMLInputElement;

  let selectedModular: EncounterSet[] = [];

  function renderDropdown(
    list: HTMLUListElement,
    wrap: HTMLElement,
    items: EncounterSet[],
    onSelect: (item: EncounterSet) => void,
  ) {
    list.innerHTML = '';
    if (items.length === 0) { wrap.classList.add('hidden'); return; }
    for (const item of items) {
      const li = document.createElement('li');
      li.textContent = item.setName + (item.packName ? ` — ${item.packName}` : '');
      li.addEventListener('mousedown', (e) => { e.preventDefault(); onSelect(item); });
      list.appendChild(li);
    }
    wrap.classList.remove('hidden');
  }

  function filterSets(sets: EncounterSet[], query: string) {
    const q = query.toLowerCase();
    return sets.filter(s => s.setName.toLowerCase().includes(q) || (s.packName ?? '').toLowerCase().includes(q));
  }

  villainSearch.addEventListener('input', () => {
    const matches = filterSets(villainSets, villainSearch.value);
    renderDropdown(villainDropdownList, villainDropdownWrap, matches, (item) => {
      villainCode.value = item.setCode;
      villainSearch.value = '';
      villainSearch.classList.add('hidden');
      villainSelectedName.textContent = item.setName;
      villainSelected.classList.remove('hidden');
      villainDropdownWrap.classList.add('hidden');
    });
  });
  villainSearch.addEventListener('blur', () => setTimeout(() => villainDropdownWrap.classList.add('hidden'), 150));

  villainClear.addEventListener('click', () => {
    villainCode.value = '';
    villainSelected.classList.add('hidden');
    villainSearch.classList.remove('hidden');
    villainSearch.value = '';
  });

  function renderModularPills() {
    modularPills.innerHTML = '';
    modularCodesInput.value = JSON.stringify(selectedModular.map(s => s.setCode));
    for (const item of selectedModular) {
      const pill = document.createElement('span');
      pill.innerHTML = `${item.setName} <button type="button" data-code="${item.setCode}">✕</button>`;
      pill.querySelector('button')!.addEventListener('click', () => {
        selectedModular = selectedModular.filter(s => s.setCode !== item.setCode);
        renderModularPills();
      });
      modularPills.appendChild(pill);
    }
  }

  modularSearch.addEventListener('input', () => {
    const already = new Set(selectedModular.map(s => s.setCode));
    const matches = filterSets(modularSets, modularSearch.value).filter(s => !already.has(s.setCode));
    renderDropdown(modularDropdownList, modularDropdownWrap, matches, (item) => {
      selectedModular.push(item);
      renderModularPills();
      modularSearch.value = '';
      modularDropdownWrap.classList.add('hidden');
    });
  });
  modularSearch.addEventListener('blur', () => setTimeout(() => modularDropdownWrap.classList.add('hidden'), 150));

  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const joinForm = document.getElementById('join-form') as HTMLFormElement;
  const createError = document.getElementById('create-error')!;
  const joinError = document.getElementById('join-error')!;

  function showError(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    createError.classList.add('hidden');
    const btn = createForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Creating…';
    const data = new FormData(createForm);
    try {
      const res = await fetch('/api/sessions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          collectionMode: data.get('collectionMode'),
          villainSetCode: (data.get('villainSetCode') as string) || null,
          modularSetCodes: JSON.parse((data.get('modularSetCodes') as string) || '[]'),
        }),
      });
      const json = await res.json();
      if (!res.ok) { showError(createError, json.error ?? 'Something went wrong'); return; }
      window.location.href = `/sessions/${json.inviteCode}`;
    } catch {
      showError(createError, 'Network error — please try again');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create Session';
    }
  });

  joinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    joinError.classList.add('hidden');
    const btn = joinForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Joining…';
    const data = new FormData(joinForm);
    const code = (data.get('code') as string).toUpperCase().trim();
    try {
      const res = await fetch(`/api/sessions/${code}/join`, { method: 'POST' });
      const json = await res.json();
      if (!res.ok) { showError(joinError, json.error ?? 'Something went wrong'); return; }
      window.location.href = `/sessions/${code}`;
    } catch {
      showError(joinError, 'Network error — please try again');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join Session';
    }
  });

  document.querySelectorAll<HTMLButtonElement>('[data-delete-session]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const code = btn.dataset.deleteSession;
      if (!code) return;
      const confirmed = await showConfirm('This cannot be undone.', { title: 'Delete session?', confirmLabel: 'Delete', danger: true });
      if (!confirmed) return;
      btn.disabled = true;
      btn.textContent = 'Deleting…';
      try {
        const res = await fetch(`/api/sessions/${code}`, { method: 'DELETE' });
        if (res.ok) {
          btn.closest('.group')?.remove();
        } else {
          await showAlert('Failed to delete session.');
          btn.disabled = false;
          btn.textContent = 'Delete';
        }
      } catch {
        await showAlert('Failed to delete session.');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });
  });
</script>
