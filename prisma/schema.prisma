// Marvel Champions Deck Builder - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Aspect {
  Basic
  Aggression
  Justice
  Leadership
  Pool
  Protection
}

enum SessionStatus {
  draft      // lobby — joining phase
  drafting   // hero/aspect pick with per-player locking
  building   // deck build phase
  completed
}

enum CollectionMode {
  single     // Use one player's collection
  combined   // Union of all collections
  duplicates // Sum of all collections
}

// Users table
model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String?
  image               String?
  isAdmin             Boolean              @default(false) @map("is_admin")
  ownedPacks          String[]             @default([])
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  
  decks               Deck[]
  hostedSessions      Session[]            @relation("HostedSessions")
  ownedSessions       Session[]            @relation("CollectionOwner")
  sessionParticipants SessionParticipant[]

  @@map("users")
}

// Decks table
model Deck {
  id          String   @id @default(uuid())
  name        String
  description String?
  heroCardId  String   @map("hero_card_id")
  aspects     Aspect[] @default([])
  cards       Json     @default("[]") // Array of { cardId, quantity }
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  heroCard    HeroCard @relation(fields: [heroCardId], references: [id])
  
  sessionParticipants SessionParticipant[]

  @@map("decks")
}

// Hero identity cards - core record for the hero
model HeroCard {
  id            String   @id
  name          String
  health        Int
  isMultiAspect Boolean  @default(false) @map("is_multi_aspect")
  cardSetCode   String?  @map("card_set_code") // For deck/encounter card relationship mapping
  packCode      String?  @map("pack_code")
  packName      String?  @map("pack_name")
  dataHash      String?  @map("data_hash") // MD5 hash for change detection
  syncedAt      DateTime @default(now()) @map("synced_at")

  identities          HeroIdentity[]
  decks               Deck[]
  deckCards           DeckCard[]
  encounterCards      EncounterCard[]
  sessionParticipants SessionParticipant[]

  @@map("hero_cards")
}

// Hero identities - each side/form of a hero
model HeroIdentity {
  id           String  @id
  heroId       String  @map("hero_id")
  identityType String  @map("identity_type") // 'hero', 'alter_ego', 'hero_2', etc.
  name         String
  attack       Int?
  defense      Int?
  handSize     Int?    @map("hand_size")
  imageUrl     String? @map("image_url")
  recover      Int?
  text         String?
  thwart       Int?
  traits       String?
  dataHash     String?  @map("data_hash") // MD5 hash for change detection

  hero HeroCard @relation(fields: [heroId], references: [id])

  @@map("hero_identities")
}

// Deck cards (allies, events, supports, upgrades, resources)
model DeckCard {
  id                  String   @id
  name                String
  type                String   // ally, event, support, upgrade, resource
  aspect              String?
  cost                Int?
  attack              Int?
  attackConsequential Int?     @map("attack_consequential")
  thwart              Int?
  thwartConsequential Int?     @map("thwart_consequential")
  health              Int?
  traits              String?
  text                String?
  imageUrl            String?  @map("image_url")
  isPermanent         Boolean  @default(false) @map("is_permanent")
  isUnique            Boolean  @default(false) @map("is_unique")
  deckLimit           Int      @default(3) @map("deck_limit")
  quantity            Int      @default(1)
  resourceEnergy      Int?     @map("resource_energy")
  resourceMental      Int?     @map("resource_mental")
  resourcePhysical    Int?     @map("resource_physical")
  resourceWild        Int?     @map("resource_wild")
  packCode            String?  @map("pack_code")
  packName            String?  @map("pack_name")
  heroId              String?  @map("hero_id")
  setType             String?  @map("set_type") // hero | hero_special for hero-specific cards
  dataHash            String?  @map("data_hash") // MD5 hash for change detection
  syncedAt            DateTime @default(now()) @map("synced_at")

  hero HeroCard? @relation(fields: [heroId], references: [id])

  @@map("deck_cards")
}

// Hero encounter cards (obligation, nemesis, villain, modular encounter sets)
model EncounterCard {
  id                 String   @id
  heroId             String?  @map("hero_id")
  setCode            String   @map("set_code")
  setName            String?  @map("set_name")
  setType            String   @map("set_type") // hero | hero_special | villain | modular | scenario | campaign
  name               String
  type               String   // obligation | minion | treachery | side_scheme | villain | main_scheme | attachment | environment
  text               String?
  traits             String?
  attack             Int?
  health             Int?
  scheme             Int?
  baseThreat         Int?     @map("base_threat")
  baseThreatFixed    Boolean  @default(false) @map("base_threat_fixed")
  baseThreatPerGroup Boolean  @default(false) @map("base_threat_per_group")
  isHealthPerHero    Boolean  @default(false) @map("is_health_per_hero")
  schemeAcceleration Int?     @map("scheme_acceleration")
  boost              Int?
  imageUrl           String?  @map("image_url")
  packCode           String?  @map("pack_code")
  packName           String?  @map("pack_name")
  quantity           Int      @default(1)
  dataHash           String?  @map("data_hash")
  syncedAt           DateTime @default(now()) @map("synced_at")

  hero HeroCard? @relation(fields: [heroId], references: [id])

  @@map("encounter_cards")
}

// Synced packs - tracks which packs have been synced and their state
model SyncedPack {
  code      String   @id
  name      String
  position  Int
  available String?  // Release date
  known     Int      // Known card count from API
  total     Int      // Total card count from API
  dataHash  String   @map("data_hash") // Hash of pack metadata for change detection
  syncedAt  DateTime @default(now()) @map("synced_at")

  @@map("synced_packs")
}

// Rules documents (for AI context/RAG)
model RulesDocument {
  id        String   @id @default(uuid())
  title     String
  section   String?
  content   String   // Full extracted text (for potential re-chunking)
  createdAt DateTime @default(now()) @map("created_at")

  chunks    DocumentChunk[]

  @@map("rules_documents")
}

// Document chunks with embeddings for RAG
model DocumentChunk {
  id         String   @id @default(uuid())
  content    String   // Chunk text (~800 chars)
  chunkIndex Int      @map("chunk_index")
  createdAt  DateTime @default(now()) @map("created_at")
  // embedding column added via raw SQL (vector(768))

  documentId String        @map("document_id")
  document   RulesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

// Multiplayer deck-building sessions
model Session {
  id                String         @id @default(uuid())
  name              String
  inviteCode        String         @unique @map("invite_code")
  status            SessionStatus  @default(draft)
  collectionMode    CollectionMode @default(combined) @map("collection_mode")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  
  hostId            String         @map("host_id")
  host              User           @relation("HostedSessions", fields: [hostId], references: [id])

  collectionOwnerId String?        @map("collection_owner_id")
  collectionOwner   User?          @relation("CollectionOwner", fields: [collectionOwnerId], references: [id])

  villainSetCode    String?        @map("villain_set_code")
  modularSetCodes   String[]       @default([]) @map("modular_set_codes")

  participants      SessionParticipant[]

  @@map("sessions")
}

// Session participants (1-4 players per session)
model SessionParticipant {
  id         String   @id @default(uuid())
  aspects    Aspect[] @default([])
  joinedAt   DateTime @default(now()) @map("joined_at")
  
  sessionId  String   @map("session_id")
  session    Session  @relation(fields: [sessionId], references: [id])
  
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  
  heroCardId String?  @map("hero_card_id")
  heroCard   HeroCard? @relation(fields: [heroCardId], references: [id])

  deckId     String?  @map("deck_id")
  deck       Deck?    @relation(fields: [deckId], references: [id])

  isLocked   Boolean  @default(false) @map("is_locked")

  @@map("session_participants")
}
